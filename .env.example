# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Multimodal Live API Model
# Default supported Live API model is gemini-3.1-flash-live-preview
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Gemini Multimodal Live API Voice
# Available voices: Aoede, Charon, Fenrir, Kore, Puck
GEMINI_VOICE=Kore

# Custom System Instruction (Optional)
# If left blank, the app defaults to an Italian military radio coordinator instruction.
GEMINI_SYSTEM_INSTRUCTION=

